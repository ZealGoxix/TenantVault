# ============================================================
# TenantVault — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# Supabase — get these from your Supabase project dashboard
# Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ⚠️  SERVICE ROLE KEY — server-side only. NEVER prefix with NEXT_PUBLIC_
# Used only for audit log writes and admin invite flow
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Resend — get from resend.com dashboard
# Used for invite emails and case-close notifications
RESEND_API_KEY=re_your_resend_api_key_here

# Your deployed app URL — used for invite link generation
# In local dev: http://localhost:3000
# In production: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
